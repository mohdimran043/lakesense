# LakeSense environment template. Copy to deploy/.env and fill in.
# NEVER commit a real .env — only this .example file (standing rule 4).

# --- Control plane ---
# Postgres DSN for control-plane metadata (the compose stack provides this).
LAKESENSE_DATABASE_URL=postgres://lakesense:lakesense@postgres:5432/lakesense?sslmode=disable
# API listen address.
LAKESENSE_HTTP_ADDR=:8080
# Path to the lsengine binary inside the backend image.
LAKESENSE_ENGINE_PATH=/usr/local/bin/lsengine
# Root directory for per-pipeline run scratch (engine config files, resumable
# state, and file-destination output). Defaults to <tmp>/lakesense if unset.
LAKESENSE_DATA_DIR=/var/lib/lakesense

# --- LLM enrichment (optional; product is fully functional without it) ---
# When empty, all LLM features fall back to raw-but-complete output.
ANTHROPIC_API_KEY=
LAKESENSE_ANTHROPIC_MODEL=claude-sonnet-5

# --- Postgres container (compose) ---
POSTGRES_USER=lakesense
POSTGRES_PASSWORD=lakesense
POSTGRES_DB=lakesense

# --- Dashboard (compose) ---
LAKESENSE_UI_PORT=3000
